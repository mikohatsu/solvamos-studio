# GEMINI_API_KEY: Gemini API (또는 Vertex ADC — 현재 생성 경로는 키 우선)
GEMINI_API_KEY=

# Hosting (Cloud Run sets PORT=8080)
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# GCP — shared PoC (dev). Product: TENANCY_MODE=isolated + Org.
GOOGLE_CLOUD_PROJECT=
SOLVAMOS_TENANT_ID=demo
CUSTOMER_TIER=starter
KMS_KEY_NAME=
VERTEX_DATA_STORE_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_COLLECTION=default_collection
GEMINI_MODEL=gemini-2.0-flash

# Google OAuth SSO (Web Client) — see docs/DRIVE_OAUTH_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
ALLOW_ADC_DRIVE=false

# Tenancy: shared = Cloud Run per tenant in one project (Lab) | isolated = cust-* under Org (product)
TENANCY_MODE=shared
# mock | shared | terraform-only | live
PROVISION_MODE=shared
# Keep false until Org + billing exist (logic present, inactive)
ENABLE_ORG_PROJECT_CREATE=false
SOLVAMOS_ORG_ID=
SOLVAMOS_CUSTOMERS_FOLDER_ID=
SOLVAMOS_BILLING_ACCOUNT=
# Lab: deploy sv-{tenant} into GOOGLE_CLOUD_PROJECT on tenant create
DEPLOY_TENANT_CLOUD_RUN=true
CLOUD_RUN_REGION=asia-northeast3
CLOUD_RUN_MIN_INSTANCES=1
# After first image build (solvamos-cloudrun/scripts/deploy.ps1):
# SHARED_CLOUD_RUN_IMAGE=asia-northeast3-docker.pkg.dev/PROJECT/REPO/studio:latest
SHARED_CLOUD_RUN_IMAGE=

# Security toggles (MUST be false on Cloud Run / production)
ALLOW_LOCAL_VAULT_FALLBACK=true
ALLOW_PAYMENT_BYPASS=true

# --- Payment / pay.sh ---
PAYMENT_NETWORK=sandbox
# Agent A2A vault default (when creating agents without explicit user wallet override)
# DEFAULT_AGENT_VAULT_PUBKEY=6xP7XpU6ZqUvS9uN8tV7nN8dM9pU8vS7nN9tU8vS7nN9
PLATFORM_TREASURY_PUBKEY=AoUNKE8uQ8y1FEtU6YSFCsopK9veP6jZ6EGNoULjdwva
PLATFORM_FEE_SHARE=0.1
DEFAULT_AGENT_FEE_USDC=0.001

# pay.sh catalog
PAYSH_CATALOG_MODE=local
