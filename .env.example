# GEMINI_API_KEY: Gemini API (또는 Vertex ADC — 현재 생성 경로는 키 우선)
GEMINI_API_KEY=

# Hosting (Cloud Run sets PORT=8080)
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# GCP — customer or platform project
GOOGLE_CLOUD_PROJECT=
SOLVAMOS_TENANT_ID=
CUSTOMER_TIER=starter
KMS_KEY_NAME=
VERTEX_DATA_STORE_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_COLLECTION=default_collection
GEMINI_MODEL=gemini-2.0-flash

# Google OAuth (customer Workspace Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Do not set OAUTH_SUCCESS_REDIRECT=/ — it drops ?session= after callback
# OAUTH_SUCCESS_REDIRECT=
# Local PoC without OAuth Web Client: use gcloud ADC + Drive API
# WARNING: Google often blocks ADC + drive.readonly ("sensitive info"). Prefer OAuth Web Client.
ALLOW_ADC_DRIVE=false

# Multitenancy provisioner
SOLVAMOS_ORG_ID=
SOLVAMOS_CUSTOMERS_FOLDER_ID=
SOLVAMOS_BILLING_ACCOUNT=
# mock | terraform-only | live
PROVISION_MODE=mock

# Security toggles (MUST be false on Cloud Run / production)
ALLOW_LOCAL_VAULT_FALLBACK=true
# For PAYMENT_NETWORK=devnet|localnet, mock proofs need this true OR use real tx signatures.
# For PAYMENT_NETWORK=sandbox, PAYSH_LOCAL_/MOCK_ proofs are accepted without this flag.
ALLOW_PAYMENT_BYPASS=true

# --- Payment / pay.sh ---
PAYMENT_NETWORK=sandbox
PLATFORM_TREASURY_PUBKEY=AoUNKE8uQ8y1FEtU6YSFCsopK9veP6jZ6EGNoULjdwva
PLATFORM_FEE_SHARE=0.1
DEFAULT_AGENT_FEE_USDC=0.001
